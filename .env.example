# ── 바이낸스 API (환경별로 다른 값) ───────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── 킬스위치 전용 독립 키 (실행 모듈 키와 별개) ───────────
KILLSWITCH_API_KEY=
KILLSWITCH_API_SECRET=

# ── 봇 내부 서명용 비밀키 (리스크-실행 토큰 서명) ─────────
INTERNAL_SIGNING_SECRET=

# ── 실행 환경: testnet | live ─────────────────────────────
RUN_MODE=testnet

# ── 알림 (모니터링·실시간 봇) ─────────────────────────────
# Bot Father 에서 받은 토큰
TELEGRAM_BOT_TOKEN=
# 복수 chat 지원: 콤마로 구분 (예: 123456789,987654321)
TELEGRAM_CHAT_IDS=
# 기존 단수형 (호환용 폴백 — 미사용 권장)
TELEGRAM_CHAT_ID=

# ── 실시간 봇 (bot/realtime) ──────────────────────────────
# 모니터링할 상위 N USDT 무기한 (거래대금 기준)
REALTIME_TOP_N_SYMBOLS=30
# 펀딩 spike 임계 (절댓값). 0.0005 = 0.05%
REALTIME_FUNDING_THRESHOLD=0.0005
# 로그 레벨: DEBUG | INFO | WARNING | ERROR
REALTIME_LOG_LEVEL=INFO
