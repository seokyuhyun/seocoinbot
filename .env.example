# ── 바이낸스 API (환경별로 다른 값) ───────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── 킬스위치 전용 독립 키 (실행 모듈 키와 별개) ───────────
KILLSWITCH_API_KEY=
KILLSWITCH_API_SECRET=

# ── 봇 내부 서명용 비밀키 (리스크-실행 토큰 서명) ─────────
INTERNAL_SIGNING_SECRET=

# ── 실행 환경: testnet | live ─────────────────────────────
RUN_MODE=testnet

# ── 알림 (모니터링 모듈) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
