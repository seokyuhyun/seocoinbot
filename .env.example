# ── 바이낸스 API (환경별로 다른 값) ───────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── 킬스위치 전용 독립 키 (실행 모듈 키와 별개) ───────────
KILLSWITCH_API_KEY=
KILLSWITCH_API_SECRET=

# ── 봇 내부 서명용 비밀키 (리스크-실행 토큰 서명) ─────────
INTERNAL_SIGNING_SECRET=

# ── 실행 환경: testnet | live ─────────────────────────────
RUN_MODE=testnet

# ── 알림 (모니터링·실시간 봇) ─────────────────────────────
# Bot Father 에서 받은 토큰
TELEGRAM_BOT_TOKEN=
# 복수 chat 지원: 콤마로 구분 (예: 123456789,987654321)
TELEGRAM_CHAT_IDS=
# 기존 단수형 (호환용 폴백 — 미사용 권장)
TELEGRAM_CHAT_ID=

# ── 실시간 봇 (bot/realtime) ──────────────────────────────
# 모니터링할 상위 N USDT 무기한 (거래대금 기준). 100 = spike 잘 나는 알트까지 포함
REALTIME_TOP_N_SYMBOLS=100
# 심볼 풀 자동 재선정 주기 (분). 60 = 1시간마다. 0 = 안 함
REALTIME_SYMBOL_REFRESH_MINUTES=60
# 펀딩 spike 임계 (절댓값). 0.0005 = 0.05% (실전 기본값)
REALTIME_FUNDING_THRESHOLD=0.0005
# 신호 표기 + paper trade 통계용 레버리지 (3~10 권장. 5 = 균형)
REALTIME_LEVERAGE=5
# 동시 보유 paper 포지션 최대
REALTIME_MAX_CONCURRENT=5
# 시간 손절 (시간 단위). 8 = 다음 펀딩 정산 주기
REALTIME_TIME_STOP_HOURS=8
# 일일 요약 자동 전송 주기 (시간). 24 = 매일. 0 = 비활성
REALTIME_DAILY_SUMMARY_HOURS=24
# 로그 레벨: DEBUG | INFO | WARNING | ERROR
REALTIME_LOG_LEVEL=INFO

# ── Upbit 봇 (bot/upbit) ──────────────────────────────────
# 별도 Telegram 봇 토큰 (Binance 봇과 분리 — BotFather 에서 새 봇 생성 필요)
UPBIT_TELEGRAM_BOT_TOKEN=
UPBIT_TELEGRAM_CHAT_IDS=
# 모니터링할 상위 N KRW 마켓 (24h 거래대금 기준)
UPBIT_TOP_N_SYMBOLS=30
UPBIT_SYMBOL_REFRESH_MINUTES=60
# REST 캔들 폴링 주기 (초)
UPBIT_CANDLE_POLL_SEC=30
# 거래량 spike 임계: 1분 거래량 / 20분 평균 ≥ 이 배수
UPBIT_VOLUME_SPIKE_MULT=3.0
UPBIT_VOLUME_AVG_MINUTES=20
# 너무 작은 마켓 제외 (1분 평균 KRW 거래대금 최소). 1000만원
UPBIT_MIN_AVG_VOL_KRW=10000000
# 같은 마켓 재발사 쿨다운 (분)
UPBIT_COOLDOWN_MINUTES=30
# 현물 — 동시 보유 / 시간 손절
UPBIT_MAX_CONCURRENT=5
UPBIT_TIME_STOP_HOURS=2
UPBIT_DAILY_SUMMARY_HOURS=24
UPBIT_LOG_LEVEL=INFO
